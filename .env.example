# phlist-server configuration
# Copy this to /etc/phlist-server/.env and fill in your values.
# In production, this file is loaded by systemd's EnvironmentFile= directive.
# After placing it: chmod 600 /etc/phlist-server/.env  (protects PHLIST_API_KEY at rest)

# Bearer token that phlist (the desktop app) sends with every write request.
# Use a long, random string — e.g.: python3 -c "import secrets; print(secrets.token_hex(32))"
PHLIST_API_KEY=change-me-to-a-long-random-string

# Directory where blocklist .txt files are stored on disk.
PHLIST_LIST_DIR=/var/lib/phlist/lists

# IP address the server binds to.
# Use 0.0.0.0 to listen on all interfaces — required if Pi-hole is NOT on Tailscale
# (e.g. Pi-hole runs on a separate LAN device). Pi-hole then uses your LAN IP.
# Use your Tailscale IP (100.x.y.z) to restrict access to Tailscale peers only.
PHLIST_HOST=0.0.0.0

# TCP port the server listens on.
PHLIST_PORT=8765

# Optional: auto-trigger Pi-hole gravity after each successful push.
# PHLIST_PIHOLE_URL=http://pi.hole
# PHLIST_PIHOLE_KEY=your_pihole_api_key
